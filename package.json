{
  "name": "playwright-project",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:chrome": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:prod": "TEST_ENV=prod playwright test",
    "test:masters": "playwright test tests/Company-master/ tests/Sales-master/ --project=chromium",
    "test:login": "playwright test tests/login.spec.ts --project=chromium-no-auth",
    "test:setup": "playwright test --project=setup --headed",
    "report": "playwright show-report",
    "codegen": "playwright codegen",
    "install:browsers": "playwright install --with-deps"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Playwright E2E Test Automation for ElevatorPlus",
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.9"
  },
  "dependencies": {
    "dotenv": "^17.2.4"
  }
}
